<?xml version="1.0" encoding="UTF-8"?>
<api name="HospitalManagementV1API"
     context="/hospital/management/v1"
     xmlns="http://ws.apache.org/ns/synapse">

    <resource methods="GET POST PUT DELETE"
              uri-template="/{backendPath+}">

        <inSequence>

            <!-- Logging -->
            <sequence key="CommonLoggingSeq"/>

            <!-- Capture backend path -->
            <property name="uri.var.backendPath"
                      expression="get-property('uri.var.backendPath')"
                      scope="default"/>

            <!-- Call backend -->
            <call>
                <endpoint key="HospitalBackendEP"/>
            </call>

            <respond/>

        </inSequence>

        <faultSequence>
            <sequence key="ErrorHandlingSeq"/>
        </faultSequence>

    </resource>

</api>